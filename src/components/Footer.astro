---
import Icon from "./Icon.astro";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/images/aes-logo-horizontal-reverse.png" alt="Adaptive Electrical Solutions" />
      <p>Safe, compliant and practical domestic, commercial and light industrial electrical work across Yeppoon, Rockhampton and Central Queensland.</p>
      <p class="licence">Electrical Licence 92589 | ARCtick Licence L209923 | ABN 45 660 857 189</p>
    </div>

    <div>
      <h2>Navigate</h2>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/services/">Services</a>
        <a href="/who-we-are/">Who we are</a>
        <a href="/contact/">Contact</a>
      </nav>
    </div>

    <div>
      <h2>Contact</h2>
      <div class="contact-links">
        <a href="tel:0402139169">
          <span class="contact-icon"><Icon name="phone" /></span>
          <span>0402 139 169</span>
        </a>
        <a href="mailto:aes.yeppoon@gmail.com">
          <span class="contact-icon"><Icon name="mail" /></span>
          <span>aes.yeppoon@gmail.com</span>
        </a>
        <span class="contact-row">
          <span class="contact-icon"><Icon name="pin" /></span>
          <span>Yeppoon & Rockhampton</span>
        </span>
        <a href="https://www.facebook.com/profile.php?id=61575010021235" target="_blank" rel="noopener noreferrer">
          <span class="contact-icon"><Icon name="facebook" /></span>
          <span>Follow us on Facebook</span>
        </a>
      </div>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>&copy; {new Date().getFullYear()} Adaptive Electrical Solutions</span>
    <span>Locally owned in Central Queensland</span>
  </div>
</footer>

<style>
  .site-footer {
    padding-top: 78px;
    color: var(--white);
    background: #17191b;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.7fr 0.7fr 1.1fr;
    gap: 72px;
    padding-bottom: 62px;
  }

  .footer-brand img {
    width: 280px;
    margin-bottom: 24px;
  }

  .footer-brand p {
    max-width: 500px;
    color: #aeb4b7;
  }

  .footer-brand .licence {
    color: var(--cyan);
    font-size: 0.86rem;
    font-weight: 650;
  }

  h2 {
    margin: 6px 0 23px;
    color: var(--cyan);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-links,
  .contact-links {
    display: grid;
    gap: 13px;
  }

  .footer-links a,
  .contact-links a {
    text-decoration: none;
  }

  .footer-links a:hover,
  .contact-links a:hover {
    color: var(--yellow);
  }

  .contact-links a,
  .contact-row {
    display: grid;
    align-items: center;
    grid-template-columns: 22px minmax(0, 1fr);
    gap: 11px;
    color: #d4d7d8;
  }

  .contact-links .contact-icon {
    display: grid;
    flex: 0 0 22px;
    width: 22px;
    min-width: 22px;
    height: 22px;
    place-items: center;
    margin: 0;
    color: var(--cyan);
  }

  .contact-icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding-block: 24px;
    border-top: 1px solid #35393c;
    color: #8f969a;
    font-size: 0.8rem;
  }

  @media (max-width: 850px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 45px;
    }

    .footer-brand {
      grid-column: auto;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
