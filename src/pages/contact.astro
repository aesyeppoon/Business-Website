---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
---

<BaseLayout
  title="Contact & Request a Quote | Adaptive Electrical Solutions"
  description="Request an electrical quote or contact Adaptive Electrical Solutions for work across Yeppoon, Rockhampton and Central Queensland."
>
  <section class="page-hero">
    <div class="page-hero__bolt"></div>
    <div class="container">
      <span class="eyebrow">Contact us</span>
      <h1>Tell us what you need help with.</h1>
      <p>
        Share the job details and property location. Your request will be sent
        straight through so we can get back to you.
      </p>
    </div>
  </section>

  <section class="contact section">
    <div class="container contact__grid">
      <div class="contact__details">
        <span class="eyebrow">Get in touch</span>
        <h2>Start with a call or request a quote.</h2>
        <p>
          For urgent electrical hazards, keep clear of the affected area and call
          as soon as it is safe to do so. For emergencies posing immediate danger,
          contact emergency services.
        </p>

        <div class="contact-cards">
          <a href="tel:0402139169">
            <span class="icon-box"><Icon name="phone" /></span>
            <span><small>Call</small>0402 139 169</span>
          </a>
          <a href="mailto:aes.yeppoon@gmail.com">
            <span class="icon-box"><Icon name="mail" /></span>
            <span><small>Email</small>aes.yeppoon@gmail.com</span>
          </a>
          <div>
            <span class="icon-box"><Icon name="pin" /></span>
            <span><small>Service area</small>Yeppoon, Rockhampton & Central Queensland</span>
          </div>
        </div>
      </div>

      <form class="quote-form" id="quote-form" action="/api/contact" method="post">
        <div class="form-heading">
          <span>Request a quote</span>
          <h2>Job details</h2>
          <p>Complete the form and it will come straight through to Adaptive Electrical Solutions.</p>
        </div>

        <div class="form-grid">
          <label class="form-honeypot" aria-hidden="true" tabindex="-1">
            <span>Company</span>
            <input type="text" name="company" autocomplete="off" tabindex="-1" />
          </label>
          <label>
            <span>Name *</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label>
            <span>Phone *</span>
            <input type="tel" name="phone" required autocomplete="tel" />
          </label>
          <label class="full">
            <span>Email</span>
            <input type="email" name="email" autocomplete="email" />
          </label>
          <label>
            <span>Property location *</span>
            <input type="text" name="location" required autocomplete="address-level2" placeholder="Suburb or town" />
          </label>
          <label>
            <span>Type of work</span>
            <select name="service">
              <option>Maintenance or fault finding</option>
              <option>Power points, switches or lighting</option>
              <option>Switchboard or safety upgrade</option>
              <option>Smoke alarms</option>
              <option>Split system air conditioning</option>
              <option>Renovation electrical work</option>
              <option>Shed wiring or new circuit</option>
              <option>Other electrical work</option>
            </select>
          </label>
          <label class="full">
            <span>Tell us about the job *</span>
            <textarea name="message" rows="6" required placeholder="What is happening, what needs to be installed, and any timing details."></textarea>
          </label>
        </div>

        <button class="button button--primary" type="submit">
          Send request <Icon name="arrow" />
        </button>
        <p class="form-note" id="form-note" aria-live="polite">
          Your details are only used to respond to this request.
        </p>
      </form>
    </div>
  </section>

  <section class="contact-note section section--soft">
    <div class="container contact-note__grid">
      <div>
        <span class="eyebrow">Helpful information</span>
        <h2>What to include in your request.</h2>
      </div>
      <ul class="check-list">
        <li><Icon name="check" /><span>The property suburb or town</span></li>
        <li><Icon name="check" /><span>A short description of the fault or planned work</span></li>
        <li><Icon name="check" /><span>When the issue started or when the work is needed</span></li>
        <li><Icon name="check" /><span>Photos of the switchboard, fitting or affected area where useful</span></li>
      </ul>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>("#quote-form");
  const note = document.querySelector<HTMLElement>("#form-note");
  const submitButton = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  const setNote = (message: string, tone = "") => {
    if (!note) return;
    note.textContent = message;
    note.dataset.tone = tone;
  };

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!form.reportValidity()) return;

    const data = new FormData(form);
    const payload = Object.fromEntries(data.entries());

    setNote("Sending your request...");
    if (submitButton) submitButton.disabled = true;

    try {
      const response = await fetch(form.action, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify(payload),
      });

      const result = await response.json().catch(() => ({
        ok: false,
        message: "Something went wrong. Please call 0402 139 169.",
      }));

      if (!response.ok || !result.ok) {
        throw new Error(result.message || "The request could not be sent.");
      }

      form.reset();
      setNote(result.message, "success");
    } catch (error) {
      setNote(error instanceof Error ? error.message : "Something went wrong. Please call 0402 139 169.", "error");
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
  });
</script>

<style>
  .contact__grid {
    display: grid;
    align-items: start;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(55px, 9vw, 120px);
  }

  .contact__details h2 {
    margin-bottom: 24px;
  }

  .contact__details > p {
    font-size: 1.05rem;
  }

  .contact-cards {
    display: grid;
    gap: 12px;
    margin-top: 42px;
  }

  .contact-cards > * {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    background: var(--white);
    font-weight: 650;
    text-decoration: none;
  }

  .contact-cards .icon-box {
    flex: 0 0 48px;
    width: 48px;
    height: 48px;
    margin: 0;
  }

  .contact-cards small {
    display: block;
    color: var(--teal);
    font-family: var(--display);
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .quote-form {
    padding: clamp(30px, 5vw, 56px);
    border-top: 10px solid var(--yellow);
    background: var(--ink);
    box-shadow: var(--shadow);
  }

  .form-heading > span {
    color: var(--cyan);
    font-family: var(--display);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .form-heading h2 {
    margin: 9px 0 12px;
    color: var(--white);
    font-size: clamp(2rem, 3vw, 3rem);
  }

  .form-heading p {
    margin-bottom: 32px;
    color: #bfc4c6;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-bottom: 28px;
  }

  .form-honeypot {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  label {
    display: grid;
    gap: 8px;
  }

  label.full {
    grid-column: 1 / -1;
  }

  label > span {
    color: #dfe2e3;
    font-family: var(--display);
    font-size: 0.75rem;
    font-weight: 700;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid #565c60;
    border-radius: 4px;
    outline: none;
    color: var(--white);
    background: #2b2e31;
  }

  input,
  select {
    height: 52px;
    padding: 0 15px;
  }

  textarea {
    min-height: 145px;
    padding: 14px 15px;
    resize: vertical;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--cyan);
    box-shadow: 0 0 0 3px rgb(53 194 213 / 15%);
  }

  .quote-form .button {
    width: 100%;
    cursor: pointer;
  }

  .quote-form .button:disabled {
    cursor: wait;
    opacity: 0.68;
  }

  .form-note {
    margin: 14px 0 0;
    color: #939a9d;
    font-size: 0.8rem;
    text-align: center;
  }

  .form-note[data-tone="success"] {
    color: var(--cyan);
  }

  .form-note[data-tone="error"] {
    color: #f8c533;
  }

  .contact-note__grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(55px, 9vw, 120px);
  }

  @media (max-width: 850px) {
    .contact__grid,
    .contact-note__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    label.full {
      grid-column: auto;
    }
  }
</style>
