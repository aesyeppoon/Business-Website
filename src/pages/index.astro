---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import Icon from "../components/Icon.astro";
import HeroLightController from "../components/react/HeroLightController.jsx";
import TestimonialExperience from "../components/react/TestimonialExperience.jsx";

const services = [
  {
    icon: "wrench",
    title: "Maintenance & fault finding",
    body: "Practical testing and repairs for tripping circuits, faulty power points, lighting faults and appliance supply issues.",
  },
  {
    icon: "board",
    title: "Switchboards & safety",
    body: "Switchboard upgrades, RCD safety switches, circuit protection, smoke alarms and general electrical safety work.",
  },
  {
    icon: "fan",
    title: "Fixtures & installations",
    body: "Power points, switches, dimmers, ceiling fans, exhaust fans, light fittings and new circuits installed neatly.",
  },
  {
    icon: "snow",
    title: "Air conditioning",
    body: "Split system installation and replacement, including electrical supply work and compliant isolation.",
  },
  {
    icon: "home",
    title: "Renovations",
    body: "Kitchen, laundry, bedroom and whole-house electrical rough-ins and fit-offs for practical renovation projects.",
  },
  {
    icon: "bolt",
    title: "Sheds & new circuits",
    body: "Shed wiring, sub-boards, underground conduit, submains and circuits for pumps, ovens, cooktops and general power.",
  },
  {
    icon: "factory",
    title: "Commercial & light industrial",
    body: "Maintenance, fault finding, power, lighting and practical electrical upgrades for small commercial and light industrial sites.",
  },
];
---

<BaseLayout
  title="Yeppoon Electrician | Adaptive Electrical Solutions"
  description="Licensed electrician for maintenance, repairs, switchboard upgrades, smoke alarms, air conditioning and renovations across Yeppoon and Rockhampton."
>
  <div class="hero-stage">
  <section class="hero">
    <div class="hero__edge"></div>
    <div class="container hero__grid">
      <div class="hero__copy">
        <span class="eyebrow">Yeppoon | Rockhampton | Central Queensland</span>
        <h1>Electrical work done properly.</h1>
        <p>
          Safe, practical electrical maintenance, repairs, upgrades and
          installations for homes, rental properties and renovations.
        </p>
        <div class="hero__actions">
            <a class="button button--primary" href="/contact/" data-quote-transition>
            Request a quote <Icon name="arrow" />
          </a>
          <a class="button button--outline" href="/services/">View services</a>
        </div>
        <div class="hero__trust">
          <span><Icon name="shield" /> Licensed & compliant</span>
          <span><Icon name="check" /> Neat workmanship</span>
          <span><Icon name="pin" /> Locally owned</span>
        </div>
      </div>

      <div class="hero__visual" aria-hidden="true">
        <div class="hero__halo"></div>
        <img src="/images/aes-mark-reverse.png" alt="" />
      </div>
    </div>
    <HeroLightController client:load />
  </section>
  </div>

  <section class="intro section">
    <div class="container intro__grid">
      <div class="section-heading">
        <span class="eyebrow">Practical. Safe. Local.</span>
        <h2>Clear advice and electrical solutions that make sense.</h2>
      </div>
      <div class="intro__copy">
        <p>
          Adaptive Electrical Solutions is a locally owned electrical business
          servicing Yeppoon, Rockhampton and the Central Queensland area.
        </p>
        <p>
          We work with homeowners, rental properties, real estate agencies,
          commercial premises, light industrial sites and renovation projects,
          focusing on straightforward communication, compliant work and a tidy finish.
        </p>
        <a class="text-link" href="/who-we-are/">
          <span>More</span><span>about</span><span>us</span><Icon name="arrow" />
        </a>
      </div>
    </div>
  </section>

  <section class="services-preview section section--soft">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Our services</span>
        <h2>From everyday repairs to major upgrades.</h2>
        <p>
          One reliable point of contact for practical residential and real
          estate electrical work.
        </p>
      </div>
      <div class="grid-3">
        {
          services.map((service) => (
            <article class="service-card card">
              <span class="icon-box">
                <Icon name={service.icon} />
              </span>
              <h3>{service.title}</h3>
              <p>{service.body}</p>
            </article>
          ))
        }
      </div>
      <a class="button button--dark services-button" href="/services/">
        Explore all services <Icon name="arrow" />
      </a>
    </div>
  </section>

  <section class="why section section--dark">
    <div class="container why__grid">
      <div class="why__image">
        <img
          src="/images/electrical-tools-header.jpg"
          alt="Electrical tools, cable and light fitting"
        />
        <span>Local electrical support across Central Queensland</span>
      </div>
      <div>
        <span class="eyebrow">Why choose Adaptive</span>
        <h2>Work you can feel confident about.</h2>
        <ul class="check-list">
          <li><Icon name="check" /><span>Clear communication before, during and after the work.</span></li>
          <li><Icon name="check" /><span>Safe, compliant solutions suited to the property.</span></li>
          <li><Icon name="check" /><span>Careful fault finding instead of guesswork.</span></li>
          <li><Icon name="check" /><span>Neat workmanship and respect for your home or rental.</span></li>
          <li><Icon name="check" /><span>Practical experience across maintenance, upgrades and renovations.</span></li>
        </ul>
        <a class="button button--primary" href="tel:0402139169">
          <Icon name="phone" /> Call 0402 139 169
        </a>
      </div>
    </div>
  </section>

  <TestimonialExperience client:load />

  <section class="process section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">A straightforward process</span>
        <h2>Simple from the first call.</h2>
      </div>
      <div class="process__grid">
        <article>
          <span>01</span>
          <h3>Tell us what you need</h3>
          <p>Call or send through the job details, property location and any useful photos.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Get a practical plan</h3>
          <p>We will clarify the issue, discuss the likely scope and arrange the right next step.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Work completed neatly</h3>
          <p>The job is carried out safely, with clear updates and a tidy finish.</p>
        </article>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>

<style>
  .hero-stage {
    position: relative;
    height: calc(100svh + 940px);
    background: var(--ink);
  }

  :global(html.aes-hero-light-complete) .hero-stage {
    height: calc(100svh - 99px);
  }

  .hero {
    position: sticky;
    z-index: 1;
    top: 99px;
    overflow: hidden;
    height: calc(100svh - 99px);
    min-height: 580px;
    color: var(--white);
    background: var(--ink);
  }

  .hero::before {
    position: absolute;
    inset: 0 0 auto;
    height: 8px;
    background: var(--yellow);
    content: "";
  }

  .hero__edge {
    position: absolute;
    inset: 0 auto 0 0;
    width: 16px;
    background: linear-gradient(90deg, var(--teal) 0 75%, var(--cyan) 75%);
  }

  .hero__grid {
    display: grid;
    height: 100%;
    align-items: center;
    grid-template-columns: minmax(0, 1.15fr) minmax(330px, 0.85fr);
    gap: 70px;
    padding-block: clamp(42px, 7vh, 72px);
  }

  .hero__copy {
    position: relative;
    z-index: 2;
    min-width: 0;
  }

  .hero h1 {
    max-width: 800px;
    margin-bottom: 26px;
  }

  .hero__copy > p {
    max-width: 680px;
    color: #d4d7d8;
    font-size: clamp(1.15rem, 2vw, 1.35rem);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin: 38px 0;
  }

  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    padding-top: 28px;
    border-top: 1px solid #3f4447;
    color: #b9bec1;
    font-size: 0.86rem;
  }

  .hero__trust span {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero__trust svg {
    width: 19px;
    color: var(--cyan);
  }

  .hero__visual {
    position: relative;
    align-self: stretch;
    overflow: hidden;
  }

  .hero__visual img {
    position: absolute;
    z-index: 2;
    top: 50%;
    left: 50%;
    width: min(430px, 110%);
    transform: translate(-48%, -50%);
  }

  .hero__halo {
    position: absolute;
    width: 500px;
    height: 590px;
    border: 66px solid rgb(255 242 0 / 17%);
    border-top-left-radius: 270px;
    right: -145px;
    top: -75px;
    transform: rotate(16deg);
  }

  .intro__grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(50px, 9vw, 130px);
  }

  .intro .section-heading {
    margin-bottom: 0;
  }

  .intro__copy p {
    font-size: 1.15rem;
  }

  .text-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: 12px;
    color: var(--ink);
    font-family: var(--display);
    font-size: 0.82rem;
    font-weight: 800;
    white-space: nowrap;
    padding-bottom: 7px;
    text-decoration: none;
    text-transform: uppercase;
  }

  .text-link span {
    padding-bottom: 5px;
    background: linear-gradient(var(--yellow), var(--yellow)) left bottom / 100% 4px no-repeat;
    transition: background-size 180ms ease;
  }

  .text-link:hover span {
    background-size: 70% 4px;
  }

  .text-link svg {
    width: 18px;
  }

  .service-card {
    position: relative;
    overflow: hidden;
    min-height: 320px;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .service-card::after {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 42px;
    height: 42px;
    background: linear-gradient(135deg, transparent 50%, var(--yellow) 50%);
    content: "";
  }

  .service-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-5px);
  }

  .services-button {
    margin-top: 38px;
  }

  .why__grid {
    display: grid;
    align-items: center;
    grid-template-columns: 1fr 0.9fr;
    gap: clamp(55px, 9vw, 120px);
  }

  .why__image {
    position: relative;
  }

  .why__image::before {
    position: absolute;
    z-index: 1;
    top: -14px;
    left: -14px;
    width: 110px;
    height: 110px;
    background: var(--yellow);
    content: "";
  }

  .why__image img {
    position: relative;
    z-index: 2;
    width: 100%;
    min-height: 0;
    padding: 28px;
    object-fit: contain;
    object-position: center;
    background: #eceeef;
    filter: saturate(0.75);
  }

  .why__image span {
    position: absolute;
    z-index: 3;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 18px 22px;
    color: var(--white);
    background: rgb(32 34 37 / 92%);
    font-family: var(--display);
    font-size: 0.75rem;
    font-weight: 750;
    text-transform: uppercase;
  }

  .why h2 {
    margin-bottom: 34px;
  }

  .why .check-list {
    margin-bottom: 38px;
  }

  .why .check-list li {
    color: #d9dcdd;
  }

  .why .check-list svg {
    color: var(--yellow);
  }

  .process__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .process__grid article {
    padding: 40px 38px 20px 0;
    border-right: 1px solid var(--line);
  }

  .process__grid article + article {
    padding-left: 38px;
  }

  .process__grid article:last-child {
    border-right: 0;
  }

  .process__grid article > span {
    display: inline-block;
    margin-bottom: 48px;
    color: var(--teal);
    font-family: var(--display);
    font-size: 0.82rem;
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero__visual {
      display: none;
    }

    .intro__grid,
    .why__grid {
      grid-template-columns: 1fr;
    }

    .process__grid {
      grid-template-columns: 1fr;
    }

    .process__grid article,
    .process__grid article + article {
      padding: 30px 0;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .process__grid article > span {
      margin-bottom: 20px;
    }
  }

  @media (max-width: 600px) {
    .hero-stage {
      height: calc(100svh + 800px);
    }

    :global(html.aes-hero-light-complete) .hero-stage {
      height: calc(100svh - 89px);
    }

    .hero {
      top: 89px;
      height: calc(100svh - 89px);
      min-height: 620px;
    }

    .hero__grid {
      padding-block: 54px;
    }

    .hero__actions {
      align-items: stretch;
      flex-direction: column;
    }

    .hero__trust {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
